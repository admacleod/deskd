<title>Hot Desk</title>
<body>
<nav>
    <h1><a href="/about">Hot Desk</a></h1>
    <a href="/">Your Bookings</a> |
    <a href="/book">Desk Booking</a>
</nav>
<div>
    <form>
        <label for="day">Choose a day:</label>
        <input type="date" id="day" name="day">
        <br/>
        <br/>
        <button type="submit">Next</button>
    </form>
</div>
</body>
</html>
