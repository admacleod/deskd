    <h2>Book a desk for 03/01/2200</h2>
    <form method="POST">
        <input type="hidden" name="_csrf" value="REGEX{\k<CSRF>}">
        <input type="radio" id="bar" name="desk" value="bar">
        <label for="bar">bar</label>
        <br/>
        <input type="radio" id="foo1" name="desk" value="foo1">
        <label for="foo1">foo1</label>
        <br/>
        <input type="radio" id="foo10" name="desk" value="foo10">
        <label for="foo10">foo10</label>
