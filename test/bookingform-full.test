    <a href="/book">Desk Booking</a>
</nav>
<div>
    <h1>Desk Booking</h1>
    <img src="/static/floorplan.png" alt="Floor plan">
    
        <h2>Current bookings for 03/01/2200</h2>
        <table>
            <thead>
            <tr>
                <th>Desk</th>
                <th>Booked By</th>
            </tr>
            </thead>
            <tbody>
            
                <tr>
                    <td>bar</td>
                    <td>me@example.com</td>
                </tr>
            
                <tr>
                    <td>foo</td>
                    <td>qux@example.com</td>
                </tr>
            
            </tbody>
        </table>
    
    
        <p>Sorry no desks are available for 03/01/2200.</p>
    
</div>
